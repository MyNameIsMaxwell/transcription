# DeepSeek API (required for summary generation)
DEEPSEEK_KEY=your_deepseek_api_key_here

# Whisper local transcription (CPU)
# Model sizes: tiny, base, small, medium, large
# CPU recommendation: tiny (fast) or base (balanced)
WHISPER_MODEL_SIZE=base

# Compute type: int8, int8_float16, float16, float32
WHISPER_COMPUTE_TYPE=int8

# Number of CPU threads for inference
WHISPER_NUM_THREADS=4

# Yandex SpeechKit cloud transcription
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here
YANDEX_LANG=ru-RU

# Optional: set custom ffmpeg path if not in PATH
# Example (Windows):
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=
